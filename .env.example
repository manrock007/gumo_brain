# Sentry (org is on the EU region — de.sentry.io)
SENTRY_ORG=gumo
SENTRY_API_BASE=https://de.sentry.io/api/0
# From the Sentry internal integration ("Claude Autofix"): Client Secret + a Token
SENTRY_CLIENT_SECRET=
SENTRY_AUTH_TOKEN=

# GitHub fine-grained PAT: contents=rw + pull-requests=rw on the mapped repos
GITHUB_TOKEN=

# Claude Code subscription auth — generate with `claude setup-token` (see README)
CLAUDE_CODE_OAUTH_TOKEN=

# ClickUp: personal API token (pk_…) + the "Sentry Autofix" list id
CLICKUP_TOKEN=
CLICKUP_LIST_ID=901615853762
CLICKUP_POLL_SECONDS=120

# Dashboard basic auth (user "gumo"). Empty = dashboard + manual trigger disabled.
DASHBOARD_PASSWORD=

# Sentry project slug -> repo mapping (JSON). setup_cmd/test_cmd/allow are optional;
# test_cmd lets Claude run the repo's unit tests inside the container.
REPO_MAP={"gumo": {"repo": "manrock007/gumoserver", "base": "master"}, "web": {"repo": "manrock007/gumowebclient", "base": "dev", "setup_cmd": "npm ci", "test_cmd": "npm test", "allow": ["Bash(npm:*)", "Bash(npx:*)", "Bash(node:*)"]}, "react-native": {"repo": "manrock007/gumoclient", "base": "master", "setup_cmd": "cd codebase/Gumo && npm ci", "test_cmd": "cd codebase/Gumo && npx jest --ci", "allow": ["Bash(npm:*)", "Bash(npx:*)", "Bash(node:*)", "Bash(cd:*)"]}, "gumo-video-analyser": {"repo": "manrock007/gumo_video_analyser", "base": "main"}}

# Grading: issues must score >= threshold (or be manually forced) to reach Claude
GRADE_MIN_SCORE=40
GRADE_STALE_DAYS=90

# Periodic sweep of top unresolved issues (legacy backlog pickup)
SWEEP_ENABLED=true
SWEEP_INTERVAL_HOURS=24
SWEEP_TOP_N=3

# Guardrails
MAX_RUNS_PER_DAY=8
ISSUE_COOLDOWN_HOURS=72
CLAUDE_TIMEOUT_SECONDS=2400
HANDLE_NEW_ISSUES=false

# Storage (volume-mounted in prod)
DATA_DIR=/data
